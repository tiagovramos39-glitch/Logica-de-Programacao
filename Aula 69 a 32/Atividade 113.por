programa {
  funcao inicio() {
    inteiro Valores[5]

    escreva("Digite um valor: ")
    leia(Valores[0])
    escreva("Digite um valor: ")
    leia(Valores[1])
    escreva("Digite um valor: ")
    leia(Valores[2])

    Valores[3] = 40
    Valores[4] = 50

    escreva(Valores[0], " - ")
    escreva(Valores[1], " - ")
    escreva(Valores[2], " - ")
    escreva(Valores[3], " - ")
    escreva(Valores[4])
  }
}
