programa
{
    funcao inicio()
    {
        real n1, n2, media

        escreva("N1: ") //Adicionei "escreva" para melhor informar o evento
        leia(n1)

        escreva("N2: ") //"escreva" adiocinado
        leia(n2)

        //media = (n1 + n2) / 3
        media = (n1 + n2) / 2

        escreva("Média: ", media)
    }
}