programa {
  funcao inicio() {
    inteiro A, B, C

    escreva("Informe o primeiro valor: ")
    leia(A)

    escreva("Informe o segundo valor: ")
    leia(B)

    se(A==B) {
      C = A + B
      escreva("A + B = ", C)}
      senao {
        C = A * B
        escreva("A * B = ", C)
      }



  }
}
