programa
{
    funcao inicio()
    {
        //inteiro largura, altura
        real largura, altura, area

        escreva("Largura: ") //"escreva" adiocinado
        leia(largura)

        escreva("Altura: ") //Adicionei os "escreva" para informar o que será calculado
        leia(altura)

        area = largura * altura

        escreva("Área: ", area)
    }
}